generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Jedna konfiguracja profilu (wzrost, referencyjna waga startowa).
model Profile {
  id                String   @id @default("default")
  heightCm          Int
  baselineWeightKg  Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Jeden wpis na dzień kalendarzowy.
model DailyEntry {
  id               String   @id @default(cuid())
  date             DateTime @unique @db.Date
  weightKg         Float?
  drankLotsOfWater Boolean  @default(false)
  mealsCorrect     Boolean  @default(false)
  ateLateNight     Boolean  @default(false)
  drankAlcohol     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
