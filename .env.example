# MySQL — dane z panelu hostingu.
DB_HOST=localhost
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydatabase
DB_PORT=3306

# Tabela i wiersz z kolumną JSON fitapp (stan aplikacji pod kluczem fitApp).
DB_FITAPP_TABLE=TranslationsGerman
DB_FITAPP_COLUMN=fitapp
DB_FITAPP_ID_COLUMN=id
DB_FITAPP_ROW_ID=1

# Opcjonalnie, gdy serwer wymaga TLS:
# DB_SSL=true
